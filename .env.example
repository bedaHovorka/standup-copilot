# Local Ollama config (no API key needed)
OLLAMA_MODEL=gemma4:latest
OLLAMA_BASE_URL=http://localhost:11434

# Optional: GitHub official remote MCP server (standup copilot features)
# Create a fine-grained PAT at https://github.com/settings/tokens
# Leave empty to run without GitHub integration.
GITHUB_PAT=
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/readonly

# Optional: push the scheduled daily summary to Slack/Discord/ntfy webhook
SUMMARY_WEBHOOK_URL=

# When your daily standup ends. After each successful run the cutoff is
# stored as <today> STANDUP_END; the next run covers everything since the
# last stored cutoff (handles weekends, vacations and sick days for free).
STANDUP_END=10:00

# Working hours - the daytime watcher only runs inside this window (Mon-Fri)
WORK_START=06:30
WORK_END=15:00
